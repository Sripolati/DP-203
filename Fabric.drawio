<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="Ofy1YR05mcdhTbPECb-v">
    <mxGraphModel dx="1414" dy="811" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="wOe7zqhs2_QcdCpgvtuy-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="In Microsoft Fabric, Dataflows Gen2 streamline end-to-end retail analytics by automatically ingesting, cleansing, and consolidating global store data from disparate sources into a unified, reusable destination for Power BI reporting, eliminating error-prone manual processing" vertex="1">
          <mxGeometry height="70" width="560" x="100" y="130" as="geometry" />
        </mxCell>
        <mxCell id="wOe7zqhs2_QcdCpgvtuy-2" parent="1" style="text;whiteSpace=wrap;html=1;" value="Dataflows Gen2 provide a low-code, cloud-based ETL/ELT tool within Microsoft Fabric, leveraging Power Query Online to cleanse, transform, and load data into a Lakehouse. These dataflows automate data preparation for self-service analysts, enabling the reuse of standardized datasets across the business to reduce source system strain. While supporting orchestrated data pipelines, they require a Fabric capacity workspace and do not support native row-level security. A key architectural benefit is the ability to transform disparate data sources into a curated, central semantic model." vertex="1">
          <mxGeometry height="120" width="560" x="120" y="270" as="geometry" />
        </mxCell>
        <mxCell id="wOe7zqhs2_QcdCpgvtuy-3" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div class=&quot;n6owBd awi2gc&quot; data-sfc-cp=&quot;&quot; data-sfc-root=&quot;ep&quot; data-sfc-cb=&quot;&quot; data-hveid=&quot;CAAIAhAA&quot; data-complete=&quot;true&quot; data-processed=&quot;true&quot; data-copy-service-computed-style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 16px; font-weight: 400; margin: 12px 0px 16px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot; style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 16px; font-weight: 400; margin: 12px 0px 16px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot;&gt;&lt;span data-subtree=&quot;aimfl&quot; data-processed=&quot;true&quot; data-copy-service-computed-style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 16px; font-weight: 400; margin: 0px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot; style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 16px; font-weight: 400; margin: 0px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot;&gt;ataflows Gen2 in Microsoft Fabric provide a low-to-no-code solution for ingesting and transforming data, leveraging Power Query Online within the Data Factory workload to load data into destinations like Lakehouses or Warehouses. The interface includes key components like the Queries pane, Diagram view for visual transformations, and a Query Settings pane to manage applied steps and data destinations. Users can perform complex transformations, such as merging and unpivoting, while utilizing the Advanced Editor to view underlying M code for optimized performance.&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;n6owBd awi2gc&quot; data-sfc-cp=&quot;&quot; data-sfc-root=&quot;ep&quot; data-sfc-cb=&quot;&quot; data-hveid=&quot;CAAIAxAA&quot; data-complete=&quot;true&quot; data-processed=&quot;true&quot; data-copy-service-computed-style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 16px; font-weight: 400; margin: 12px 0px 16px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot; style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 16px; font-weight: 400; margin: 12px 0px 16px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot;&gt;&lt;strong class=&quot;Yjhzub&quot; data-sfc-root=&quot;c&quot; data-sfc-cb=&quot;&quot; data-complete=&quot;true&quot; data-processed=&quot;true&quot; data-copy-service-computed-style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 16px; font-weight: 600; margin: 0px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot; style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 16px; font-weight: 600; margin: 0px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot;&gt;Dataflow Gen2 Architecture Flow&lt;/strong&gt;&lt;/div&gt;&lt;div class=&quot;Fsg96&quot; data-sfc-cp=&quot;&quot; data-sfc-root=&quot;c&quot; data-sfc-cb=&quot;&quot; data-complete=&quot;true&quot; data-processed=&quot;true&quot; data-sfc-inited=&quot;2&quot; data-copy-service-computed-style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 14px; font-weight: 400; margin: 0px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot; style=&quot;font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: 14px; font-weight: 400; margin: 0px; text-decoration: none; border-bottom: 0px none rgb(10, 10, 10);&quot;&gt;&lt;/div&gt;&lt;div class=&quot;r1PmQe&quot; data-sfc-root=&quot;c&quot; data-wiz-uids=&quot;Y2Zzbf_p,Y2Zzbf_o&quot; data-sfc-cb=&quot;&quot; data-hveid=&quot;CAAIBBAA&quot; data-complete=&quot;true&quot; data-processed=&quot;true&quot; data-copy-service-